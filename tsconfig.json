{
  "compilerOptions": {
    // Environment — Node.js CommonJS (alinhado com "type": "commonjs" no package.json)
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],

    // Strict type checking
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Output
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,

    // Interop
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
